# Copy to .env.local (never commit .env.local).
# Optional: improves AI reason text; omit for heuristic-only reasons.
OPENAI_API_KEY=

# Optional: Google Places (New) Text Search for public rating/review counts (server-side only).
GOOGLE_MAPS_API_KEY=

# Optional: in-memory cap on outbound Google Places calls per UTC day (default 500). Serverless instances reset per cold start.
MAX_GOOGLE_REVIEW_CALLS_PER_DAY=
DATABASE_URL=
NEXT_PUBLIC_APP_URL=

# Stripe placeholders for B2C checks and premium.
# TODO: Replace with real Stripe IDs/secrets in production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SINGLE_CHECK=
STRIPE_PRICE_FIVE_CHECKS=
STRIPE_PRICE_TWENTY_CHECKS=
STRIPE_PRICE_PREMIUM_MONTHLY=
