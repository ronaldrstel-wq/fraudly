# Copy to .env.local (never commit .env.local).
# Optional: improves AI reason text; omit for heuristic-only reasons.
OPENAI_API_KEY=
CRON_SECRET=
URLHAUS_API_KEY=
PHISHTANK_API_KEY=
GOOGLE_WEB_RISK_API_KEY=
ADMIN_USER_IDS=
ADMIN_EMAILS=

# Optional: Google Safe Browsing API key for phishing/malware flags (required for live lookups).
GOOGLE_SAFE_BROWSING_API_KEY=

# Modular intelligence toggles (preferred names). Legacy ENABLE_* aliases are still honored.
ENABLE_GOOGLE_SAFE_BROWSING=true
ENABLE_OPENPHISH=true
ENABLE_URLHAUS=true
ENABLE_POLICE_NL=true
ENABLE_RDAP=true
ENABLE_SSL_CHECK=true

# Legacy aliases (still supported): ENABLE_SAFE_BROWSING, ENABLE_OPENPHISH_CHECK,
# ENABLE_URLHAUS_CHECK, ENABLE_POLICE_CHECK, ENABLE_RDAP_CHECK.

# Timing & cache overrides (milliseconds). Safe defaults apply when unset.
PROVIDER_TIMEOUT_MS=
PROVIDER_FETCH_TIMEOUT_MS=
CACHE_TTL_SAFE_BROWSING_MS=
CACHE_TTL_OPENPHISH_MS=
CACHE_TTL_URLHAUS_MS=
CACHE_TTL_POLICE_NL_MS=
CACHE_TTL_RDAP_MS=
CACHE_TTL_SSL_MS=

# Tier 2 stubs (surface “pending integration” rows only when true).
ENABLE_PHISHTANK=false
ENABLE_ABUSEIPDB=false
ENABLE_VIRUSTOTAL=false
ENABLE_TRANCO=false
ENABLE_UMBRELLA=false
ENABLE_GOV_CYBER_UK=false
ENABLE_GOV_CYBER_US=false
ENABLE_GOV_CYBER_DE=false
ENABLE_GOV_CYBER_FR=false
DATABASE_URL=
# Public site URL, no trailing slash (Stripe success/cancel URLs).
NEXT_PUBLIC_APP_URL=

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Stripe placeholders for B2C checks and premium.
# TODO: Replace with real Stripe IDs/secrets in production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SINGLE_CHECK=
STRIPE_PRICE_FIVE_CHECKS=
STRIPE_PRICE_TWENTY_CHECKS=
STRIPE_PRICE_PREMIUM_MONTHLY=

# Optional: Public-only reputation enrichment (server-side only)
ENABLE_PUBLIC_INTEL_ENRICHMENT=true
ENABLE_PUBLIC_INTEL_TRUSTPILOT=true
ENABLE_PUBLIC_INTEL_REDDIT=true
ENABLE_PUBLIC_INTEL_SCAMADVISER=true
ENABLE_PUBLIC_INTEL_DNS=true
ENABLE_PUBLIC_INTEL_SSL=true
ENABLE_PUBLIC_INTEL_RDAP=true

# Optional public source toggle for indexed snippet collection.
ENABLE_PUBLIC_INTEL_GOOGLE_INDEXED_REVIEWS=true

# Optional paid/private source flags (disabled by default)
ENABLE_OUTSCRAPER_ENRICHMENT=false
ENABLE_GOOGLE_PLACES_REVIEWS=false
ENABLE_TRUSTPILOT_PRIVATE_API=false

# Temporary dev/testing flag: force scam alert ingestion to publish all ingested alerts.
SCAM_ALERTS_FORCE_PUBLISH=false
# Admin key for bulk refresh endpoint: /api/admin/recalculate-latest-checks
ADMIN_RECALC_KEY=
