generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserPlan {
  free
  premium
}

enum SubscriptionStatus {
  inactive
  active
  canceled
  past_due
}

enum ScamAlertStatus {
  draft
  published
  archived
}

model User {
  id                   String             @id @default(cuid())
  authProvider         String             @default("legacy")
  authProviderId       String?            @unique
  email                String?            @unique
  plan                 UserPlan           @default(free)
  credits              Int                @default(0)
  freeChecksUsed       Int                @default(0)
  monthlyChecksUsed    Int                @default(0)
  paidChecksCount      Int                @default(0)
  subscriptionStatus   SubscriptionStatus @default(inactive)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  recentSearches       RecentSearch[]
}

/// Private per-user / per-session fraud check history (not publicly exposed).
model RecentSearch {
  id                  String   @id @default(cuid())
  userId              String?
  user                User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Opaque key for anonymous browsers (httpOnly cookie); never shown in analytics exports as PII tied to Clerk.
  anonymousSessionKey String?  @db.VarChar(64)
  originalQuery       String   @db.Text
  normalizedQuery     String   @db.VarChar(2048)
  entityType          String   @db.VarChar(32)
  trustScoreSnap      Int?
  verdictSnap         String?  @db.VarChar(32)
  resultPath          String   @db.VarChar(2048)
  hiddenFromUserAt    DateTime?
  hiddenFromUserBy    String?  @db.VarChar(32)
  publicVisible       Boolean  @default(true)
  createdAt           DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([anonymousSessionKey, createdAt(sort: Desc)])
  @@index([publicVisible, createdAt(sort: Desc)])
}

model StripeEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

/// Anonymized, user-unlinked summaries for `/latest-checks` discovery only — never populated from `/recent-searches`.
model LatestPublicCheck {
  id                 String   @id @default(cuid())
  normalizedValue    String   @unique @db.VarChar(2048)
  checkedValue       String   @db.VarChar(4096)
  entityType         String   @db.VarChar(64)
  riskScoreSnapshot  Int
  statusLabel        String   @db.VarChar(128)
  publicResultPath   String   @db.VarChar(2048)
  firstSeenAt        DateTime @default(now())
  lastSeenAt         DateTime @default(now()) @updatedAt

  @@index([lastSeenAt(sort: Desc)])
}

/// Cached aggregated reputation enrichment for normalized domains (Outscraper-backed).
model ReputationEnrichmentCache {
  id                 String   @id @default(cuid())
  normalizedDomain   String   @unique @db.VarChar(2048)
  provider           String   @default("outscraper") @db.VarChar(64)
  status             String   @db.VarChar(32)
  payload            Json?
  fetchError         String?  @db.Text
  estimatedCostUsd   Float?
  fetchedAt          DateTime @default(now())
  expiresAt          DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([expiresAt])
}

model ScamSignal {
  id               String   @id @default(cuid())
  source           String   @db.VarChar(64)
  sourceRef        String?  @db.VarChar(512)
  url              String?  @db.VarChar(4096)
  domain           String?  @db.VarChar(2048)
  normalizedDomain String?  @db.VarChar(2048)
  scamType         String?  @db.VarChar(128)
  affectedBrand    String?  @db.VarChar(128)
  riskLevel        String   @db.VarChar(16)
  confidence       Float
  firstSeenAt      DateTime?
  lastSeenAt       DateTime?
  evidenceJson     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([source, lastSeenAt(sort: Desc)])
  @@index([normalizedDomain, lastSeenAt(sort: Desc)])
  @@index([scamType, lastSeenAt(sort: Desc)])
  @@unique([source, sourceRef])
}

model ScamAlert {
  id                 String          @id @default(cuid())
  slug               String          @unique @db.VarChar(256)
  title              String          @db.VarChar(256)
  scamType           String          @db.VarChar(128)
  affectedBrand      String?         @db.VarChar(128)
  riskLevel          String          @db.VarChar(16)
  summary            String          @db.Text
  safetyTips         String[]        @db.Text
  evidenceCount      Int             @default(0)
  exampleDomainsJson Json?
  sourceSummaryJson  Json?
  status             ScamAlertStatus @default(draft)
  generatedAt        DateTime        @default(now())
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([status, generatedAt(sort: Desc)])
  @@index([scamType, generatedAt(sort: Desc)])
}
