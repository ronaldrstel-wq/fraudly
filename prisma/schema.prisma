generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserPlan {
  free
  premium
}

enum SubscriptionStatus {
  inactive
  active
  canceled
  past_due
}

/// How the user authenticated (Clerk OAuth provider) — not purchase platform.
enum IdentityAuthProvider {
  apple
  google
  email
  unknown
}

enum AuthSurface {
  website
  ios
  android
}

/// Verified purchase channel — only set by Stripe webhook or RevenueCat (never from login provider).
enum EntitlementSource {
  none
  stripe
  app_store
  google_play
}

enum ClientPlatform {
  web
  ios
  android
}

enum ScamAlertStatus {
  draft
  published
  archived
}

enum DomainOverrideVerdict {
  trusted
  suspicious
  high_risk
  none
}

model User {
  id                   String               @id @default(cuid())
  /// Auth system linkage (`clerk` | `legacy`) — not Apple/Google/email identity.
  authProvider         String               @default("legacy")
  authProviderId       String?              @unique
  email                String?              @unique
  /// Clerk OAuth identity (apple/google/email) — does not imply App Store / Play entitlement.
  identityProvider     IdentityAuthProvider @default(unknown)
  lastAuthSurface      AuthSurface          @default(website)
  entitlementActive    Boolean              @default(false)
  entitlementSource    EntitlementSource    @default(none)
  entitlementProductId String?              @db.VarChar(128)
  entitlementExpiresAt DateTime?
  lastDetectedPlatform ClientPlatform       @default(web)
  /// Optional RevenueCat / mobile app user id for cross-surface entitlement sync.
  revenueCatAppUserId  String?              @unique @db.VarChar(128)
  plan                 UserPlan             @default(free)
  credits              Int                  @default(0)
  freeChecksUsed       Int                  @default(0)
  monthlyChecksUsed    Int                  @default(0)
  paidChecksCount      Int                  @default(0)
  subscriptionStatus   SubscriptionStatus   @default(inactive)
  stripeCustomerId     String?              @unique
  stripeSubscriptionId String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  recentSearches       RecentSearch[]
}

/// Private per-user / per-session fraud check history (not publicly exposed).
model RecentSearch {
  id                  String   @id @default(cuid())
  userId              String?
  user                User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Opaque key for anonymous browsers (httpOnly cookie); never shown in analytics exports as PII tied to Clerk.
  anonymousSessionKey String?  @db.VarChar(64)
  originalQuery       String   @db.Text
  normalizedQuery     String   @db.VarChar(2048)
  entityType          String   @db.VarChar(32)
  trustScoreSnap      Int?
  verdictSnap         String?  @db.VarChar(32)
  resultPath          String   @db.VarChar(2048)
  createdAt           DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([anonymousSessionKey, createdAt(sort: Desc)])
}

model StripeEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

/// Anonymized, user-unlinked summaries for `/latest-checks` discovery only — never populated from `/recent-searches`.
model LatestPublicCheck {
  id                 String   @id @default(cuid())
  normalizedValue    String   @unique @db.VarChar(2048)
  checkedValue       String   @db.VarChar(4096)
  entityType         String   @db.VarChar(64)
  riskScoreSnapshot  Int
  statusLabel        String   @db.VarChar(128)
  publicResultPath   String   @db.VarChar(2048)
  firstSeenAt        DateTime @default(now())
  lastSeenAt         DateTime @default(now()) @updatedAt

  @@index([lastSeenAt(sort: Desc)])
}

/// Cached aggregated reputation enrichment for normalized domains (Outscraper-backed).
model ReputationEnrichmentCache {
  id                 String   @id @default(cuid())
  normalizedDomain   String   @unique @db.VarChar(2048)
  provider           String   @default("outscraper") @db.VarChar(64)
  status             String   @db.VarChar(32)
  payload            Json?
  fetchError         String?  @db.Text
  estimatedCostUsd   Float?
  fetchedAt          DateTime @default(now())
  expiresAt          DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([expiresAt])
}

model ScamAlert {
  id                String          @id @default(cuid())
  title             String          @db.VarChar(256)
  slug              String          @unique @db.VarChar(256)
  summary           String          @db.Text
  scamType          String          @db.VarChar(64)
  affectedBrand     String?         @db.VarChar(256)
  domain            String?         @db.VarChar(512)
  url               String?         @db.VarChar(2048)
  sourceName        String          @db.VarChar(128)
  sourceUrl         String?         @db.VarChar(2048)
  confidence        Int             @default(50)
  riskLevel         String          @default("medium") @db.VarChar(32)
  status            ScamAlertStatus @default(draft)
  safetyTips        String[]        @default([])
  sourceSummaryJson Json?
  exampleDomainsJson Json?
  evidenceCount     Int             @default(0)
  whyRisky          String?         @db.Text
  firstSeenAt       DateTime        @default(now())
  lastSeenAt        DateTime        @default(now())
  generatedAt       DateTime        @default(now())
  publishedAt       DateTime?
  archivedAt        DateTime?
  /// Public listing hides rows past this instant (aligned with first publish + 90d visibility).
  expiresAt         DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  signals           ScamSignal[]

  @@index([status, publishedAt(sort: Desc)])
  @@index([status, archivedAt(sort: Desc)])
  @@index([scamType, status])
  @@index([domain])
}

model ScamSignal {
  id          String    @id @default(cuid())
  alertId     String
  alert       ScamAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  sourceName  String    @db.VarChar(128)
  sourceUrl   String?   @db.VarChar(2048)
  signalType  String    @db.VarChar(64)
  content     String    @db.Text
  domain      String?   @db.VarChar(512)
  url         String?   @db.VarChar(2048)
  confidence  Int       @default(50)
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([signalType, sourceName])
  @@index([domain])
  @@index([url])
}

/// Audit + counting source for Postgres-backed `/api/check` rate limits (no raw IP or UA stored).
model ScanRateLimitEvent {
  id            String   @id @default(cuid())
  userId        String?
  ipHash        String   @db.VarChar(128)
  userAgentHash String   @db.VarChar(128)
  abuseKey      String   @db.VarChar(128)
  domain        String   @db.VarChar(512)
  /// `"basic"` or `"deep"` (full pipeline / detailLevel full).
  scanType      String   @db.VarChar(16)
  createdAt     DateTime @default(now())
  blocked       Boolean  @default(false)
  reason        String?  @db.VarChar(256)

  @@index([ipHash, createdAt(sort: Desc)])
  @@index([abuseKey, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

/// Optional trust-analysis attachments for a URL check (no FK until a first-class Scan model exists).
model ScanEvidence {
  id               String   @id @default(cuid())
  scanId           String?  @db.VarChar(64)
  url              String?  @db.VarChar(2048)
  /// `screenshot` | `social_ad` | `webshop_signals`
  evidenceType     String   @db.VarChar(32)
  imageUrl         String?  @db.VarChar(2048)
  imageHash        String?  @db.VarChar(128)
  sourcePlatform   String?  @db.VarChar(64)
  adText           String?  @db.Text
  detectedText     String?  @db.Text
  extractedSignals Json?
  riskDelta        Int      @default(0)
  summary          String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([url, createdAt(sort: Desc)])
  @@index([evidenceType, createdAt(sort: Desc)])
}

model DomainAdminOverride {
  id              String               @id @default(cuid())
  domain          String               @unique @db.VarChar(2048)
  overrideVerdict DomainOverrideVerdict @default(none)
  note            String?              @db.Text
  createdByUserId String?              @db.VarChar(128)
  createdByEmail  String?              @db.VarChar(320)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model ScanAdminActionLog {
  id              String   @id @default(cuid())
  actionType      String   @db.VarChar(64)
  domain          String?  @db.VarChar(2048)
  scanId          String?  @db.VarChar(64)
  metadata        Json?
  createdByUserId String?  @db.VarChar(128)
  createdByEmail  String?  @db.VarChar(320)
  createdAt       DateTime @default(now())

  @@index([actionType, createdAt(sort: Desc)])
  @@index([domain, createdAt(sort: Desc)])
}
